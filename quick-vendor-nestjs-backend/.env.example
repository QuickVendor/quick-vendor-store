# =====================================================================
# QuickVendor Backend — Environment Variables
# =====================================================================
# Copy to .env (local) or .env.staging / .env.production for other envs.
# APP_ENV is the source of truth — it drives storage driver, Paystack
# mode validation, CORS strictness, and Sentry environment.
#
#   APP_ENV=local       → uploads/ folder, Paystack TEST,  lax CORS
#   APP_ENV=staging     → S3,             Paystack TEST,  strict CORS
#   APP_ENV=production  → S3,             Paystack LIVE,  strict CORS
#
# Mismatched values fail boot loudly. Don't try to override the contract.
# =====================================================================

APP_ENV=local

# ── Database ──
# Use "db" hostname inside docker compose; "localhost" for native yarn dev.
DATABASE_URL="postgresql://quickvendor:quickvendor_dev@localhost:5432/quickvendor_dev"
POSTGRES_USER=quickvendor
POSTGRES_PASSWORD=quickvendor_dev
POSTGRES_DB=quickvendor_dev

# ── JWT ──
# Local: any string is fine. Non-local: ≥32 chars, NOT the default.
SECRET_KEY=dev-secret-change-in-production
JWT_EXPIRATION_MINUTES=10080

# ── Storage ──
# Leave unset to derive from APP_ENV (local→local, staging/prod→s3).
# Override only when intentionally testing the S3 path against MinIO etc.
# STORAGE_DRIVER=local

# ── AWS S3 (only required when STORAGE_DRIVER=s3) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=

# ── Paystack ──
# APP_ENV=local|staging  → MUST be sk_test_/pk_test_
# APP_ENV=production     → MUST be sk_live_/pk_live_
# Webhook secret is required in staging/production.
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_WEBHOOK_SECRET=
PLATFORM_FEE_PERCENTAGE=5

# ── Redis ──
# Optional locally (falls back to in-memory token blocklist). Strongly
# recommended in staging/production — required for multi-instance.
REDIS_URL=

# ── Observability ──
SENTRY_DSN=
# SENTRY_ENVIRONMENT defaults to APP_ENV — only set to override.
# SENTRY_ENVIRONMENT=

# ── Notifications (optional) ──
SLACK_WEBHOOK_URL=
FEEDBACK_SECRET_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="QuickVendor <noreply@quickvendor.store>"

# ── WhatsApp validation (Abstract API, ~$0.01/lookup) ──
ABSTRACT_API_KEY=
WHATSAPP_VALIDATION_ENABLED=false

# ── HTTP ──
PORT=3000
BASE_URL=http://localhost:3000
# Comma-separated for multiple frontends (storefront,admin).
# In local, localhost:* origins are auto-allowed regardless.
FRONTEND_URL=http://localhost:3001,http://localhost:3002
