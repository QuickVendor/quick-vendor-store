# =================================================
# QuickVendor NestJS Backend — Environment Variables
# =================================================
# Copy this file to .env and fill in the values.
# For staging/production, copy to .env.staging / .env.production

# Database — Dockerized Postgres
# Use "db" as host when running inside Docker Compose.
# Use "localhost" when running natively (yarn dev without Docker).
DATABASE_URL="postgresql://quickvendor:quickvendor_dev@db:5432/quickvendor_dev"
POSTGRES_USER=quickvendor
POSTGRES_PASSWORD=quickvendor_dev
POSTGRES_DB=quickvendor_dev

# JWT
SECRET_KEY="dev-secret-change-in-production"
JWT_EXPIRATION_MINUTES=10080

# Storage — "local" for dev, "s3" for staging/production
STORAGE_DRIVER=local

# AWS S3 (only used when STORAGE_DRIVER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Slack (optional)
SLACK_WEBHOOK_URL=
FEEDBACK_SECRET_KEY=

# Email (SMTP — optional, enables order confirmation emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="QuickVendor <noreply@quickvendor.com>"

# Redis (optional — enables distributed token blocklist for multi-instance)
REDIS_URL=

# WhatsApp validation (Abstract API — optional, ~$0.01/lookup)
ABSTRACT_API_KEY=
WHATSAPP_VALIDATION_ENABLED=true

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_WEBHOOK_SECRET=whsk_xxx
PLATFORM_FEE_PERCENTAGE=5

# General
PORT=3000
BASE_URL=http://localhost:3000
# Comma-separated for multiple frontends: storefront,admin
FRONTEND_URL=http://localhost:5173
