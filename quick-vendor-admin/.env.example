# =====================================================================
# QuickVendor Admin — Environment Variables
# =====================================================================
# Mirrors the storefront contract. Admin accounts are seeded via the
# backend's `yarn db:seed` — never created via public registration.
# =====================================================================

NEXT_PUBLIC_APP_ENV=local

NEXT_PUBLIC_API_URL=http://localhost:3000
INTERNAL_API_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3002
